# =============================================================
# Cadence — Production Environment Variables
# Copy to .env and fill in real values. NEVER commit .env!
# =============================================================

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=your_strong_postgres_password_here

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=your_long_random_jwt_secret_here_minimum_32_chars

# ── App URLs ──────────────────────────────────────────────────
# Frontend origin (used for CORS)
CLIENT_URL=https://app.yourcadencedomain.com

# ── Email (SendGrid) ──────────────────────────────────────────
# Leave blank to disable email features
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# ── Push Notifications (Firebase) ────────────────────────────
# Leave blank to disable push notifications
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── AWS (used by scripts, not Docker directly) ────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
