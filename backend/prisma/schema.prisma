// Prisma v7 schema — datasource has NO url field (set via prisma.config.ts)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Role {
  ATHLETE
  COACH
  ASSISTANT_COACH
  TEACHER
  AD
  ADMIN
}

enum BlockType {
  CLASS
  STUDY
  PERSONAL
  ATHLETIC
}

enum Visibility {
  PUBLIC
  BUSY
  PRIVATE
}

enum BlockSource {
  MANUAL
  SIS_SYNC
  CALENDAR_SYNC
}

enum EventType {
  PRACTICE
  GAME
  TRAVEL
  FILM
  MEETING
}

enum AttendeeStatus {
  REQUIRED
  OPTIONAL
  EXCUSED
}

enum Division {
  D1
  D2
  D3
  NAIA
  NJCAA
}

enum VenueType {
  GYM
  FIELD
  POOL
  COURT
}

enum Platform {
  WEB
  IOS
  ANDROID
}

enum GradeTerm {
  FALL
  SPRING
  SUMMER
}

// ─────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────

model School {
  id         String   @id @default(cuid())
  name       String
  timezone   String   @default("America/Chicago")
  conference String?
  division   Division?
  logoUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users   User[]
  teams   Team[]
  venues  Venue[]
  grades  Grade[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ATHLETE)
  schoolId  String
  teamId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school         School          @relation(fields: [schoolId], references: [id])
  team           Team?           @relation(fields: [teamId], references: [id])
  scheduleBlocks ScheduleBlock[]
  eventsCreated  Event[]         @relation("EventCreator")
  attendances    EventAttendee[]
  caraLogs       CARALog[]
  shareLinks     ShareLink[]
  googleToken    GoogleToken?
  fcmTokens          FCMToken[]
  playerProfile      PlayerProfile?
  todoItems          TodoItem[]
  gradesEntered      Grade[]         @relation("GradeTeacher")
  gradesReceived     Grade[]         @relation("GradeAthlete")
  assistantCoachTeams AssistantCoachTeam[]
  tripsCreated       Trip[]          @relation("TripCreator")
}

model Team {
  id                  String  @id @default(cuid())
  sport               String
  division            Division
  schoolId            String
  complianceRulesetId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  school             School              @relation(fields: [schoolId], references: [id])
  complianceRuleset  ComplianceRuleset?  @relation(fields: [complianceRulesetId], references: [id])
  members            User[]
  events             Event[]
  assistantCoaches   AssistantCoachTeam[]
  trips              Trip[]
}

model AssistantCoachTeam {
  id             String @id @default(cuid())
  userId         String
  teamId         String
  canManageRoster Boolean @default(false)
  canSchedule    Boolean @default(true)
  canViewGrades  Boolean @default(true)
  canViewTravel  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model ScheduleBlock {
  id          String      @id @default(cuid())
  userId      String
  title       String?
  start       DateTime
  end         DateTime
  type        BlockType
  isHardBlock Boolean     @default(true)
  visibility  Visibility  @default(BUSY)
  source      BlockSource @default(MANUAL)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Event {
  id          String    @id @default(cuid())
  teamId      String
  title       String
  notes       String?   @default("")
  start       DateTime
  end         DateTime
  type        EventType
  isVoluntary Boolean   @default(false)
  venueId     String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tripId      String?

  team        Team            @relation(fields: [teamId], references: [id])
  venue       Venue?          @relation(fields: [venueId], references: [id])
  createdBy   User            @relation("EventCreator", fields: [createdById], references: [id])
  attendees   EventAttendee[]
  caraLogs    CARALog[]
  bookings    VenueBooking[]
  trip        Trip?           @relation(fields: [tripId], references: [id])
}

model EventAttendee {
  eventId String
  userId  String
  status  AttendeeStatus @default(REQUIRED)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@id([eventId, userId])
}

model Trip {
  id             String   @id @default(cuid())
  teamId         String
  destination    String
  hotelName      String?
  hotelAddress   String?
  hotelPhone     String?
  checkIn        DateTime?
  checkOut       DateTime?
  departTime     DateTime?
  returnTime     DateTime?
  foodOptions    Json?    // [{name, address, type, meal_time}]
  notes          String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  team      Team    @relation(fields: [teamId], references: [id])
  createdBy User    @relation("TripCreator", fields: [createdById], references: [id])
  events    Event[]
}

model ComplianceRuleset {
  id                 String   @id @default(cuid())
  division           Division @unique
  maxCaraHoursDay    Float
  maxCaraHoursWeek   Float
  deadWeekRules      Json?
  mandatoryRestHours Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teams Team[]
}

model CARALog {
  id        String   @id @default(cuid())
  athleteId String
  eventId   String?
  hours     Float
  weekStart DateTime
  createdAt DateTime @default(now())

  athlete User   @relation(fields: [athleteId], references: [id])
  event   Event? @relation(fields: [eventId], references: [id])
}

model Venue {
  id       String    @id @default(cuid())
  schoolId String
  name     String
  type     VenueType
  capacity Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school   School         @relation(fields: [schoolId], references: [id])
  events   Event[]
  bookings VenueBooking[]
}

model VenueBooking {
  id      String   @id @default(cuid())
  venueId String
  eventId String?
  start   DateTime
  end     DateTime

  venue Venue  @relation(fields: [venueId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])
}

model ShareLink {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model GoogleToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FCMToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  Platform @default(WEB)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NEW MODELS ──────────────────────────────────────────────

model PlayerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  hometown     String?
  likes        String?  // comma-separated or JSON array
  dislikes     String?
  foodAllergies String?
  bio          String?
  photoUrl     String?
  jerseyNumber Int?
  position     String?
  height       String?
  weight       Int?
  year         String?  // Freshman, Sophomore, Junior, Senior
  major        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TodoItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  priority    String   @default("medium") // low, medium, high
  category    String?  // academics, athletics, personal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Grade {
  id         String   @id @default(cuid())
  schoolId   String
  athleteId  String
  teacherId  String
  courseName String
  grade      String   // A, B+, B, etc.
  term       GradeTerm
  year       Int
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  school   School @relation(fields: [schoolId], references: [id])
  athlete  User   @relation("GradeAthlete", fields: [athleteId], references: [id])
  teacher  User   @relation("GradeTeacher", fields: [teacherId], references: [id])

  @@unique([athleteId, courseName, term, year])
}
